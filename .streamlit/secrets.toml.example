# Copy this file to secrets.toml and fill in values for the environment you're connecting to.
# secrets.toml is gitignored — never commit it.
#
# LOCAL DEV (Windows auth to your VM):
#   Leave the [database] table out entirely and db.py falls back to a Windows-auth
#   connection to StockDevVM.
#
# CLOUD DEPLOY (Streamlit Cloud → Azure SQL, via pymssql):
#   Uncomment + fill the [database] section below. Streamlit Cloud reads these from
#   the secrets management UI (App settings → Secrets), not this file.
#   No driver key needed — the cloud path uses pymssql (FreeTDS), not ODBC.

# [database]
# server = "your-server.database.windows.net"
# database = "StrategyXL_Share"
# username = "your-sql-user"
# password = "your-sql-password"

# Optional: gate access with a single shared password. Leave commented for fully public.
# [auth]
# password = "your-shared-password"
